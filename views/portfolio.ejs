<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= portfolio.fullName %> | LiquiLink</title>
    <meta
      name="description"
      content="Portfolio of <%= portfolio.fullName %>, <%= portfolio.role %>."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="theme-<%= portfolio.theme || 'dark' %> layout-<%= portfolio.layoutVariant || 'default' %>">
    <div class="aurora aurora--one"></div>
    <div class="aurora aurora--two"></div>

    <header class="site-header">
      <nav class="container nav">
        <p class="brand"><%= portfolio.fullName %></p>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#experience">Experience</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section class="hero container">
        <div class="hero-content">
          <p class="eyebrow"><%= portfolio.role %></p>
          <h1>
            <%= portfolio.fullName %>
            <span><%= portfolio.headline %></span>
          </h1>
          <p class="hero-text"><%= portfolio.heroText %></p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#projects">View Work</a>
            <a class="btn btn-ghost" href="#contact">Let’s Connect</a>
          </div>
        </div>

        <aside class="hero-card">
          <p class="card-label"><%= portfolio.shippingTitle %></p>
          <h2><%= portfolio.shippingHeading %></h2>
          <p><%= portfolio.shippingDescription %></p>
          <ul>
            <% portfolio.shippingPoints.forEach((point) => { %>
            <li><%= point %></li>
            <% }) %>
          </ul>
        </aside>
      </section>

      <% if ((portfolio.layoutVariant || "default") === "projects-first") { %>
      <section id="projects" class="container section">
        <div class="section-title">
          <p>Featured Projects</p>
          <h2>Selected work that blends precision and creativity.</h2>
        </div>
        <div class="project-grid">
          <% portfolio.projects.forEach((project, idx) => { %>
          <article class="project-card">
            <div class="project-head">
              <p><%= String(idx + 1).padStart(2, "0") %></p>
              <span><%= project.platform %></span>
            </div>
            <h3><%= project.title %></h3>
            <p><%= project.description %></p>
          </article>
          <% }) %>
        </div>
      </section>

      <section id="about" class="container section">
        <div class="section-title">
          <p>About</p>
          <h2>Human-centered engineering, pixel-perfect execution.</h2>
        </div>
        <div class="about-grid">
          <% portfolio.aboutCards.forEach((card) => { %>
          <article class="glass-card">
            <h3><%= card.title %></h3>
            <p><%= card.description %></p>
          </article>
          <% }) %>
        </div>
      </section>
      <% } else { %>
      <section id="about" class="container section">
        <div class="section-title">
          <p>About</p>
          <h2>Get to know more about me.</h2>
        </div>
        <div class="about-grid">
          <% portfolio.aboutCards.forEach((card) => { %>
          <article class="glass-card">
            <h3><%= card.title %></h3>
            <p><%= card.description %></p>
          </article>
          <% }) %>
        </div>
      </section>

      <section id="projects" class="container section">
        <div class="section-title">
          <p>Featured Projects</p>
          <h2>Here's what I've done so far.</h2>
        </div>
        <div class="project-grid">
          <% portfolio.projects.forEach((project, idx) => { %>
          <article class="project-card">
            <div class="project-head">
              <p><%= String(idx + 1).padStart(2, "0") %></p>
              <span><%= project.platform %></span>
            </div>
            <h3><%= project.title %></h3>
            <p><%= project.description %></p>
          </article>
          <% }) %>
        </div>
      </section>
      <% } %>

      <section id="experience" class="container section">
        <div class="section-title">
          <p>Experience</p>
          <h2>A brief timeline of my journey.</h2>
        </div>
        <div class="timeline">
          <% portfolio.experiences.forEach((item) => { %>
          <article class="timeline-item">
            <p class="timeline-date"><%= item.period %></p>
            <h3><%= item.title %></h3>
            <p><%= item.description %></p>
          </article>
          <% }) %>
        </div>
      </section>
    </main>

    <footer id="contact" class="footer">
      <div class="container footer-content">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Let’s build something extraordinary.</h2>
          <p class="footer-note">
            Open to speaking engagements, mentorship, and product collaborations.
          </p>
        </div>
        <div class="contact-links">
          <% if (portfolio.email) { %>
          <a href="mailto:<%= portfolio.email %>"
            ><i class="fa-solid fa-envelope" aria-hidden="true"></i>Email</a
          >
          <% } %>
          <% if (portfolio.linkedin) { %>
          <a href="<%= portfolio.linkedin %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-linkedin" aria-hidden="true"></i>LinkedIn</a
          >
          <% } %>
          <% if (portfolio.youtube) { %>
          <a href="<%= portfolio.youtube %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-youtube" aria-hidden="true"></i>YouTube</a
          >
          <% } %>
          <% if (portfolio.instagram) { %>
          <a href="<%= portfolio.instagram %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-instagram" aria-hidden="true"></i>Instagram</a
          >
          <% } %>
          <% if (portfolio.twitter) { %>
          <a href="<%= portfolio.twitter %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-x-twitter" aria-hidden="true"></i>Twitter</a
          >
          <% } %>
          <% if (portfolio.github) { %>
          <a href="<%= portfolio.github %>" target="_blank" rel="noreferrer"
            ><i class="fa-brands fa-github" aria-hidden="true"></i>GitHub</a
          >
          <% } %>
        </div>
      </div>
      <p class="copyright">© 2026 <%= portfolio.fullName %>. All rights reserved.</p>
    </footer>
  </body>
</html>
